# FFLogs API 配置（开发环境）
# 复制此文件为 .dev.vars 并填入实际的密钥

# v1 API Key
FFLOGS_API_KEY=your_v1_api_key_here

# v2 OAuth Credentials
FFLOGS_CLIENT_ID=your_client_id_here
FFLOGS_CLIENT_SECRET=your_client_secret_here

# 手动同步接口鉴权令牌
# 生成方式: openssl rand -hex 32
SYNC_AUTH_TOKEN=your_secret_token_here

# FFLogs OAuth 用户登录（Authorization Code Flow）
# 复用上方的 FFLOGS_CLIENT_ID/SECRET，无需额外 OAuth App
# redirect_uri 由 /api/auth/callback 根据请求来源域名自动推导（白名单校验），无需在此配置

# JWT 签名密钥（HMAC-SHA256），生成方式: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here

# 敏感词过滤 HMAC 密钥（HMAC-SHA256）
# 生成方式: openssl rand -base64 32
# 本地 .dev.vars 与线上 Workers Secret 两处必须同值
SENSITIVE_WORDS_HMAC_KEY=your_hmac_key_here

# FFLogs 反向代理（可选，默认留空）
# 留空时 FFLogs 请求直连上游——本地开发通常保持留空即可。
# 仅在需要本地验证代理链路时才填：两项必须同时填，且 SECRET 与 Caddy 侧同值。
# 部署与 Caddy 配置见 deploy/fflogs-proxy/README.md
# FFLOGS_PROXY_BASE=https://ffproxy.xivhealer.com
# FFLOGS_PROXY_SECRET=your_proxy_secret_here
